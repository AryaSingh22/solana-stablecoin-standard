{
    "name": "@stbr/sss-token",
    "version": "0.1.0",
    "description": "TypeScript SDK for the Solana Stablecoin Standard (SSS)",
    "license": "MIT",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@coral-xyz/anchor": "^0.30.1",
        "@solana/spl-token": "^0.4.0",
        "@solana/web3.js": "^1.95.0",
        "bs58": "^5.0.0",
        "fastify": "5.7.4",
        "mocha": "5.0.5"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "eslint": "^10.0.1",
        "tsup": "^8.0.0",
        "typescript": "^5.4.0",
        "vitest": "^4.0.18"
    }
}