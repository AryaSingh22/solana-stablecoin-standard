{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "outDir": "target/types",
        "types": [
            "mocha",
            "chai",
            "node"
        ]
    },
    "include": [
        "tests/**/*.ts",
        "target/types/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "target",
        "sdk",
        "cli",
        "services"
    ]
}